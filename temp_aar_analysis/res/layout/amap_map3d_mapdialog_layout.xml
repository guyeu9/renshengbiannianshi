<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#fafafa"
            android:orientation="vertical">

            <TextView
                android:id="@+id/amap_map3d_dialog_title"
                android:layout_width="match_parent"
                android:layout_height="33dp"
                android:gravity="center"
                android:text="北京市"
                android:textColor="#898989" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0.5dip"
                android:background="@drawable/amap_map3d_divider_vertical_bright_opaque" />

            <TextView
                android:id="@+id/amap_map3d_dialog_status"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_below="@id/amap_map3d_dialog_title"
                android:background="#ffffff"
                android:gravity="center"
                android:text="暂停"
                android:textColor="#4c90f9" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0.5dip"
                android:background="@drawable/amap_map3d_divider_vertical_bright_opaque" />

            <TextView
                android:id="@+id/amap_map3d_dialog_delete"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_below="@id/amap_map3d_dialog_status"
                android:background="#ffffff"
                android:gravity="center"
                android:text="取消下载"
                android:textColor="#FF0000" />

            <TextView
                android:id="@+id/amap_map3d_dialog_cancle"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_below="@id/amap_map3d_dialog_status"
                android:layout_marginTop="9dp"
                android:background="#ffffff"
                android:gravity="center"
                android:text="取消"
                android:textColor="#000000" />
        </LinearLayout>
    </RelativeLayout>
</RelativeLayout>
