<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f3f3f3">

    <RelativeLayout
        android:id="@+id/amap_map3d_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RelativeLayout
            android:id="@+id/amap_map3d_download_title_layout"
            android:layout_width="match_parent"
            android:layout_height="39dp"
            android:background="#fafafa">

            <ImageView
                android:id="@+id/amap_map3d_download_title_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true"
                android:layout_marginLeft="10dp"
                android:background="@drawable/amap_map3d_title_back" />

            <TextView
                android:id="@+id/amap_map3d_download_title_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="离线地图"
                android:textColor="#000000"
                android:textSize="@dimen/amap_map3d_font_34" />
        </RelativeLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="41dp"
            android:layout_below="@id/amap_map3d_download_title_layout"
            android:background="#ffffff"
            android:focusable="true"
            android:focusableInTouchMode="true">

            <ImageView
                android:id="@+id/amap_map3d_search_input_searchimg"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:layout_centerVertical="true"
                android:layout_marginLeft="95dip"
                android:background="@drawable/amap_map3d_sousuo"
                android:scaleType="centerInside" />

            <AutoCompleteTextView
                android:id="@+id/amap_map3d_search_input"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginBottom="5dp"
                android:layout_marginLeft="15dp"
                android:layout_marginRight="15dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/amap_map3d_shape"
                android:hint="输入城市名称或拼音"
                android:paddingLeft="105dip"
                android:singleLine="true"
                android:textColor="#000000"
                android:textColorHint="#a6a6a6" />

            <ImageView
                android:id="@+id/amap_map3d_search_input_clean"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:layout_marginRight="20dp"
                android:scaleType="centerInside"
                android:src="@drawable/amap_map3d_route_history_close"
                android:visibility="gone" />
        </RelativeLayout>
    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/amap_map3d_footer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/amap_map3d_header"
        android:layout_marginTop="@dimen/amap_map3d_font_24">

        <ExpandableListView
            android:id="@+id/amap_map3d_city_listview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

        </ExpandableListView>

    </RelativeLayout>


    <ListView
        android:id="@+id/amap_map3d_search_listview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/amap_map3d_header"
        android:layout_marginTop="@dimen/amap_map3d_font_32"
        android:visibility="gone">

    </ListView>
</RelativeLayout>
